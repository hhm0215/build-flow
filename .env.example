# ─────────────────────────────────────────
# BuildFlow 환경변수 설정
# 이 파일을 복사하여 .env 로 사용하세요
# cp .env.example .env
# ─────────────────────────────────────────

# MySQL
DB_ROOT_PASSWORD=buildflow123
DB_USERNAME=root
DB_PASSWORD=buildflow123

# JWT (최소 32자 이상의 랜덤 문자열)
JWT_SECRET=buildflow-jwt-secret-key-must-be-at-least-32-characters-long

# Claude API (estimate-service AI 파싱용)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
